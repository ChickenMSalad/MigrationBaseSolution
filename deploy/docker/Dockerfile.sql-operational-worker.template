# P8.1H template: SQL operational worker container image
# Build from repository root.

FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY . .
RUN dotnet publish ./src/Hosts/Migration.Hosts.SqlOperationalWorker/Migration.Hosts.SqlOperationalWorker.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/runtime:9.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "Migration.Hosts.SqlOperationalWorker.dll"]
