```gitignore
# =========================================================
# Build Outputs
# =========================================================

**/bin/
**/obj/
[Bb]in/
[Oo]bj/
out/
artifacts/
TestResults/
coverage/
coverage-*/
*.trx
*.coverage
*.coveragexml

# =========================================================
# .NET / Visual Studio
# =========================================================

*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

*.nupkg
*.snupkg
*.symbols.nupkg

project.lock.json
project.assets.json

.nuget/
packages/

*.cache
*.pdb

.vs/
.idea/

.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json

# =========================================================
# Node / Frontend
# =========================================================

node_modules/
dist/
build/
.vite/

vite.config.*.timestamp-*

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================================
# OS Files
# =========================================================

.DS_Store
Thumbs.db
desktop.ini

# =========================================================
# Temp Files
# =========================================================

tmp/
temp/

*.tmp
*.temp
*.bak
*.swp
*.swo

# =========================================================
# Environment / Local Config
# =========================================================

.env
.env.*
!.env.example

*.local

appsettings.Local.json
appsettings.*.Local.json
appsettings.Development.local.json

# Keep canonical configs tracked
!appsettings.Development.json
!appsettings.example.json

# NEVER ignore all appsettings globally
# Production config should be environment-managed,
# not committed.

local.settings.json
*.publishsettings

# =========================================================
# Secrets / Credentials
# =========================================================

credentials/
credential-artifacts/
tokens/
secrets/
private/

*.pfx
*.pem
*.key
*.cer
*.crt
*.keystore
*.jks

# =========================================================
# Logs
# =========================================================

logs/
*.log
*.tlog

# =========================================================
# Azurite / Local Storage
# =========================================================

.azurite/
azurite/
local-azurite/

__azurite_db_*.json
__azurite_db_*

*.azurite

azurite_debug.log

# =========================================================
# Migration Runtime State
# =========================================================

.migration-control-plane/
__queuestorage__/

src/Workers/Migration.Workers.QueueExecutor/Runtime/

# =========================================================
# Generated Migration Outputs
# =========================================================

migration-output/
migration-outputs/

exports/
exported-manifests/

generated-manifests/
manifests/generated/

runs/output/
runs/logs/

worker-output/

failed-rows/
retry-output/

# =========================================================
# Data Exports
# =========================================================

*.csv
*.tsv

!*.example.csv
!*.sample.csv

# =========================================================
# Archives
# =========================================================

*.zip
*.7z
*.rar

# =========================================================
# Keep Intentional Example Assets
# =========================================================

!README.md
!.gitignore

!**/.gitkeep

!**/fixtures/**
!**/samples/**
!**/examples/**

!**/*.example.json

# =========================================================
# Explicit Project Allows
# =========================================================

!src/Migration.Manifest.Csv/
!src/Migration.Manifest.Csv/**

src/Migration.Manifest.Csv/bin/
src/Migration.Manifest.Csv/obj/
```
