**/credentials/**
**/credential-artifacts/**
**/secrets/**
**/private/**
**/config/local/**
**/config/dev/**

# CSV / manifest exports (these can contain real asset data)
*.csv
*.tsv

# Exception: allow sample files only
!*.example.csv
!*.sample.csv

