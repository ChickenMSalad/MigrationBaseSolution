{
  "ControlPlane": {
    "StorageRoot": "az://migration-control-plane-dev"
  },
  "AzureBlobStorage": {
    "AccountName": "<storage-account-name>",
    "ContainerName": "migration-control-plane-dev",
    "UseManagedIdentity": true
  },
  "Cloud": {
    "DeploymentProfile": "dev",
    "HostKind": "azureAppService",
    "StorageMode": "azureBlob",
    "ArtifactMode": "azureBlob",
    "ArtifactStorageAccountName": "<storage-account-name>"
  }
}
