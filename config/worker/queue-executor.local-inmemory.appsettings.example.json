{
  "MigrationRunQueue": {
    "Provider": "InMemory",
    "QueueName": "migration-runs"
  },
  "QueueWorkerLoop": {
    "Enabled": false,
    "DryRun": true,
    "MaxMessages": 1,
    "PollIntervalSeconds": 10,
    "VisibilityTimeoutSeconds": 300,
    "CompleteMessages": false
  },
  "QueueExecutorCoordinator": {
    "DryRun": true,
    "CompleteMessages": false,
    "WriteFailureArtifacts": true,
    "MaxMessages": 1
  }
}
