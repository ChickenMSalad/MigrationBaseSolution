{
  "largeManifestValidation": {
    "profileName": "large-manifest-sql-operational-validation",
    "environmentName": "prod-like",
    "expectedManifestRowCount": 1500000,
    "minimumAcceptedManifestRowCount": 500000,
    "maximumAcceptedManifestRowCount": 2000000,
    "expectedShardCount": 32,
    "maximumRowsPerShard": 50000,
    "maximumManifestLoadDuration": "00:20:00",
    "maximumQueueProjectionDuration": "00:20:00",
    "maximumOperationalQueryDuration": "00:00:05",
