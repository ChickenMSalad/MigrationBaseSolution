      "severity": "Blocking",
      "expectedEvidenceKey": "manifest.rowCount",
      "blocksProductionReadiness": true
    },
    {
      "checkName": "sql-operational-store-is-source-of-truth",
      "category": "sql",
      "description": "Confirms operational execution state is durable in SQL rather than Excel or transient files.",
      "severity": "Blocking",
      "expectedEvidenceKey": "operationalStore.sql.enabled",
      "blocksProductionReadiness": true
    },
    {
      "checkName": "resume-markers-exist-for-large-run",
      "category": "resumability",
      "description": "Confirms large-run resume markers are persisted before production promotion.",
      "severity": "Required",
      "expectedEvidenceKey": "resumability.markerCount",
      "blocksProductionReadiness": true
    }
  ]
