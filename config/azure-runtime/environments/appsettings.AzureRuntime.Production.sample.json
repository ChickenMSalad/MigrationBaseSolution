{
  "AzureRuntime": {
    "EnvironmentName": "Production",
    "Region": "eastus",
    "UseManagedIdentity": true,
    "RequireProductionSafetyChecks": true
  },
  "AzureRuntimeHosting": {
    "EnableCloudOnlyGuards": true,
    "EnableDeploymentSlotGuards": true,
    "AllowLocalDeveloperCredentials": false,
    "DefaultWorkerReplicaCount": 2,
    "DefaultWorkerConcurrency": 4
  }
}
