{
  "AzureRuntime": {
    "Environment": {
      "EnvironmentName": "local",
      "DeploymentRing": "dev",
      "Region": "local",
      "InstanceName": "migration-local"
    },
    "OperationalSql": {
      "ConnectionStringName": "MigrationOperationalSql",
      "RequireEncryptedConnection": true,
      "CommandTimeoutSeconds": 60
    },
    "ArtifactStorage": {
      "AccountName": "",
      "ContainerName": "migration-artifacts",
      "UseManagedIdentity": true
    },
    "QueueTopology": {
      "Provider": "AzureStorageQueues",
      "RunQueueName": "migration-run-work",
      "ReplayQueueName": "migration-replay-work",
      "DeadLetterQueueName": "migration-dead-letter"
    },
    "Telemetry": {
      "ApplicationInsightsConnectionStringName": "APPLICATIONINSIGHTS_CONNECTION_STRING",
      "CloudRoleName": "migration-runtime",
      "EnableStructuredOperationalEvents": true
    }
  }
}
