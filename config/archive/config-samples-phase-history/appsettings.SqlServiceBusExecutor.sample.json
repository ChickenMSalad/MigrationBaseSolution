{
  "ConnectionStrings": {
    "MigrationOperationalStore": "Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<database>;Authentication=Active Directory Default;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "OpenTelemetry": {
    "EnableTracing": true,
    "EnableAzureMonitorExporter": false
  },
  "SqlOperationalWorkItemQueue": {
    "ConnectionStringName": "MigrationOperationalStore",
    "SchemaName": "migration",
    "WorkItemsTableName": "WorkItems",
    "DefaultMaxAttempts": 5
  },
  "SqlOperationalMigrationJobExecutor": {
    "Enabled": true
  },
  "GenericMigrationRuntime": {
    "RegisterAllWhenEmpty": true,
    "EnabledManifests": [ "Csv" ],
    "EnabledSources": [ "LocalStorage" ],
    "EnabledTargets": [ "LocalStorage" ]
  },
  "SqlServiceBusExecutor": {
    "ServiceBusConnectionString": "Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<key-name>;SharedAccessKey=<key>",
    "QueueName": "migration-operational-work-items",
    "WorkerId": "cloud-servicebus-executor-001",
    "MaxConcurrentCalls": 8,
    "RetryDelaySeconds": 120,
    "CompleteWithoutExecutingMigration": false
  }
}
