{
  "ConnectionStrings": {
    "MigrationOperationalStore": "Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<database>;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "SqlServiceBusDispatcher": {
    "Enabled": true,
    "SqlConnectionString": "<same-as-ConnectionStrings:MigrationOperationalStore>",
    "ServiceBusConnectionString": "Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<key-name>;SharedAccessKey=<secret>",
    "QueueName": "migration-operational-work-items"
  },
  "SqlServiceBusExecutor": {
    "ServiceBusConnectionString": "Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<key-name>;SharedAccessKey=<secret>",
    "QueueName": "migration-operational-work-items"
  },
  "SqlOperationalWorkItemQueue": {
    "SchemaName": "migration",
    "WorkItemsTableName": "WorkItems"
  },
  "SqlOperationalMigrationJobExecutor": {
    "Enabled": true
  },
  "GenericMigrationRuntime": {
    "RegisterAllWhenEmpty": true,
    "EnabledManifests": [],
    "EnabledSources": [],
    "EnabledTargets": []
  },
  "OpenTelemetry": {
    "EnableTracing": true,
    "EnableAzureMonitorExporter": false
  }
}
