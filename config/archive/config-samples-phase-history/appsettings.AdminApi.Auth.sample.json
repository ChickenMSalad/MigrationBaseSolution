{
  "AdminApi": {
    "Authentication": {
      "Mode": "EntraId",
      "EntraId": {
        "Authority": "https://login.microsoftonline.com/<tenant-id>/v2.0",
        "TenantId": "<tenant-id>",
        "Audience": "api://<admin-api-application-id>",
        "RequireHttpsMetadata": true
      }
    },
    "Authorization": {
      "RequiredRoles": [
        "Migration.Operator",
        "Migration.Administrator"
      ]
    }
  }
}
