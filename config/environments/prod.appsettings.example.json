{
  "Cloud": {
    "DeploymentProfile": "prod",
    "HostKind": "azureAppService",
    "Region": "eastus",
    "Sku": "P1v3",
    "CredentialMode": "managedIdentity",
    "ArtifactMode": "azureBlob",
    "KeyVaultUri": "https://<key-vault-name>.vault.azure.net/",
    "ArtifactContainerName": "migration-artifacts-prod",
    "ArtifactStorageAccountName": "<storage-account-name>",
    "QueueStorageAccountName": "<storage-account-name>",
    "RequiresHttps": true,
    "RequiresAuth": true,
    "RequiresPrivateNetworking": true,
    "EnablesDiagnostics": true,
    "EnablesHealthProbes": true
  },
  "Workspace": {
    "TenantMode": "singleTenant",
    "TenantEnforced": true,
    "TenantId": "<tenant-id>",
    "WorkspaceId": "prod",
    "DisplayName": "Production Workspace"
  },
  "ControlPlane": {
    "StorageRoot": "az://migration-control-plane-prod"
  },
  "MigrationRunQueue": {
    "Provider": "AzureQueue",
    "QueueName": "migration-runs-prod",
    "StorageAccountName": "<storage-account-name>"
  },
  "Auth": {
    "Authority": "https://login.microsoftonline.com/<tenant-id>/v2.0",
    "Audience": "api://<admin-api-client-id>"
  }
}
