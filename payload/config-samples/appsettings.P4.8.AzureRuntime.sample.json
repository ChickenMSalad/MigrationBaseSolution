{
  "ConnectionStrings": {
    "MigrationOperationalStore": "Server=tcp:<sql-server>.database.windows.net,1433;Initial Catalog=migration-operational;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "SqlOperationalStore": {
    "ConnectionStringName": "MigrationOperationalStore",
    "CommandTimeoutSeconds": 60
  },
  "ServiceBus": {
    "FullyQualifiedNamespace": "<namespace>.servicebus.windows.net",
    "ConnectionString": "<development-only-or-local-secret>",
    "WorkItemQueueName": "migration-work-items"
  },
  "ApplicationInsights": {
    "ConnectionString": "<application-insights-connection-string>"
  },
  "Azure": {
    "KeyVaultUri": "https://<key-vault-name>.vault.azure.net/",
    "AppConfigurationEndpoint": "https://<app-configuration-name>.azconfig.io",
    "StorageAccountName": "<storage-account-name>"
  }
}
