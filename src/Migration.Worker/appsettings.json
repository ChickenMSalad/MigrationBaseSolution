{
  "ConnectionStrings": {
    "MigrationOperationalStore": "Server=localhost;Database=MigrationOperational;Integrated Security=True;TrustServerCertificate=True"
  },
  "MigrationRuntime": {
    "SqlOperationalRuntime": {
      "EnableHostedWorker": true,
      "EnableReadinessProbe": true,
      "ReadinessCommandTimeoutSeconds": 15
    },
    "SqlOperationalWorker": {
      "Enabled": true,
      "WorkerId": "local-dev-worker-01",
      "BatchSize": 25,
      "LeaseSeconds": 300,
      "RetryDelaySeconds": 300,
      "IdleDelayMilliseconds": 5000,
      "RunUntilIdleAndStop": false
    }
  }
}
