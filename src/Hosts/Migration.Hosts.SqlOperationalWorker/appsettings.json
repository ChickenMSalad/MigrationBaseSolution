{
  "ConnectionStrings": {
    "MigrationOperationalStore": "Server=(localdb)\\MSSQLLocalDB;Database=MigrationOperationalStore;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "MigrationRuntime": {
    "SqlOperationalWorker": {
      "Enabled": true,
      "WorkerId": "local-dev-sql-operational-worker-01",
      "BatchSize": 25,
      "LeaseSeconds": 300,
      "RetryDelaySeconds": 300,
      "IdleDelayMilliseconds": 5000,
      "RunUntilIdleAndStop": false
    },
    "CloudRuntimeComposition": {
      "ReadinessTimeoutSeconds": 30,
      "RequireSqlReadiness": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
