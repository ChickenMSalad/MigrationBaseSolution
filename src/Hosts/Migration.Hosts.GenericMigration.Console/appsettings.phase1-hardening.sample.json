{
  "MigrationExecution": {
    "ResumeCompletedWorkItems": true,
    "MaxDegreeOfParallelism": 1,
    "StopOnFirstError": false,
    "StatePath": "Runtime/migration-state",
    "Retry": {
      "MaxAttempts": 3,
      "InitialDelayMilliseconds": 750,
      "MaxDelayMilliseconds": 30000,
      "BackoffMultiplier": 2.0,
      "UseJitter": true,
      "NonRetryableExceptionTypeNames": [
        "InvalidOperationException",
        "ArgumentException",
        "FileNotFoundException"
      ]
    },
    "Validation": {
      "RequireBinaryForTargetWrites": true,
      "RequiredManifestColumns": [ "webdam_id" ],
      "TreatWarningsAsErrors": false
    }
  }
}
