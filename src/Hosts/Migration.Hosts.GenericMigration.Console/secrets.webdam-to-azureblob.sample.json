{
  "WebDam": {
    "BaseUrl": "https://YOUR-WEBDAM-HOST.example.com",
    "ClientId": "YOUR-WEBDAM-CLIENT-ID",
    "ClientSecret": "YOUR-WEBDAM-CLIENT-SECRET",
    "RefreshToken": "YOUR-WEBDAM-REFRESH-TOKEN"
  },
  "AzureBlobTarget": {
    "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=YOURACCOUNT;AccountKey=YOURKEY;EndpointSuffix=core.windows.net",
    "ContainerName": "migration-test",
    "RootFolderPath": "webdam-export/ntara",
    "CreateContainerIfMissing": true,
    "Overwrite": false,

    "PreserveSourceFolderPath": true,
    "SourceFolderPathField": "Folder Path",

    "UniqueIdField": "webdam_id",
    "FileNameField": "File Name",
    "BinaryFileNameTemplate": "{uniqueid}_{filename}",

    "WriteMetadataSidecar": true,
    "MetadataFileNameTemplate": "{uniqueid}_metadata.json",
    "MetadataSidecarMode": "All",
    "IncludeEmptyMetadataValues": false,
    "PrettyPrintMetadataSidecar": true,

    "WriteBlobMetadata": true,
    "IncludeMappedFieldsAsBlobMetadata": false,
    "IncludeSourceColumnsAsBlobMetadata": false
  }
}
