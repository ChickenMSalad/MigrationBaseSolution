{
  "AdminApi": {
    "StorageRoot": "Runtime/admin-api"
  },
  "MigrationRunQueue": {
    "Provider": "None",
    "ConnectionString": "UseDevelopmentStorage=true",
    "QueueName": "migration-runs",
    "CreateIfMissing": true
  },
  "QueueExecutor": {
    "PollDelaySeconds": 5,
    "MaxMessagesPerPoll": 1,
    "VisibilityTimeoutMinutes": 30,
    "DeleteMessageWhenRunRecordIsMissing": true,
    "ExecuteRuns": true
  },
  "MigrationExecution": {
    "MaxDegreeOfParallelism": 1,
    "ResumeCompletedWorkItems": true,
    "StopOnFirstError": false,
    "StateStore": "JsonFile"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
